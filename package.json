{
  "name": "career-agent-hub",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5173 --open",
    "dev:fresh": "vite --host 127.0.0.1 --port 5173 --open --force",
